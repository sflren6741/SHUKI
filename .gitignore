# Obsidian workspace/cache (keep your own local UI state out of the repo)
# Use .obsidian/* (not .obsidian/) so the negation below can punch through
.obsidian/*
# ...but publish the plugin list so Obsidian auto-prompts to install them
!.obsidian/community-plugins.json

# Claude Code local state (only agents/ and skills/ are published)
.claude/*
!.claude/agents/
!.claude/skills/

# Runtime / generated output (personal — never commit)
00_Intranet/agent-runs/
00_Intranet/monitoring/
00_Intranet/local-ai-runs/

# OS / editor cruft
.DS_Store
Thumbs.db
desktop.ini

# Images & binaries (this is a docs/framework repo)
*.png
*.jpg
*.jpeg
*.gif
*.pdf
